[project]
name = "{{project_name}}"
version = "0.1.0"
description = "Script generado con xrom-scripts"
readme = "README.md"
requires-python = ">=3.12"
authors = [
    { name = "Xrom Systems" }
]
dependencies = [
    "xrom-scripts @ git+https://github.com/ChecoOnlineDev/xrom-scripts-v2.git",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.metadata]
allow-direct-references = true

[tool.hatch.build.targets.wheel]
packages = ["src/{{project_name}}"]

[tool.hatch.build]
include = [
    "src/{{project_name}}/**/*",
]
